{
  "name": "chatit",
  "version": "0.1.0",
  "description": "CC - Agentic Chatit.Cloud Code Assistant - Terminal AI coding agent with support for multiple providers",
  "type": "module",
  "main": "dist/chatit.js",
  "bin": {
    "chatit": "src/main.tsx"
  },
  "scripts": {
    "dev": "bun run src/main.tsx",
    "build": "bun build src/main.tsx --outfile dist/chatit.js",
    "start": "node dist/chatit.js",
    "test": "bun test",
    "format": "biome format src --write",
    "lint": "biome lint src"
  },
  "dependencies": {
    "react": "^19.0.0",
    "ink": "^5.0.0",
    "chalk": "^5.0.0",
    "@commander-js/extra-typings": "^13.0.0",
    "commander": "^12.0.0",
    "zod": "^4.0.0",
    "lodash-es": "^4.17.21",
    "@opencode-ai/sdk": "^1.3.4",
    "openai": "^4.40.0",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "keywords": [
    "ai",
    "cli",
    "code",
    "assistant",
    "chatit",
    "claude",
    "terminal",
    "coding"
  ],
  "author": "Chatit Contributors",
  "license": "MIT"
}
